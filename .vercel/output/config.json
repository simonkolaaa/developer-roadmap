{
	"version": 3,
	"routes": [
		{
			"src": "^/(.*)/$",
			"headers": {
				"Location": "/$1"
			},
			"status": 308
		},
		{
			"src": "^/ai-tutor$",
			"headers": {
				"Location": "/ai"
			},
			"status": 301
		},
		{
			"src": "^/best-practices/api-security$",
			"headers": {
				"Location": "/api-security-best-practices"
			},
			"status": 301
		},
		{
			"src": "^/best-practices/aws$",
			"headers": {
				"Location": "/aws-best-practices"
			},
			"status": 301
		},
		{
			"src": "^/best-practices/backend-performance$",
			"headers": {
				"Location": "/backend-performance-best-practices"
			},
			"status": 301
		},
		{
			"src": "^/best-practices/code-review$",
			"headers": {
				"Location": "/code-review-best-practices"
			},
			"status": 301
		},
		{
			"src": "^/best-practices/frontend-performance$",
			"headers": {
				"Location": "/frontend-performance-best-practices"
			},
			"status": 301
		},
		{
			"src": "^/best-practices$",
			"headers": {
				"Location": "/roadmaps"
			},
			"status": 301
		},
		{
			"src": "^/devops/devops-engineer$",
			"headers": {
				"Location": "/devops"
			},
			"status": 301
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)$",
			"dest": "_render"
		},
		{
			"src": "^/_image$",
			"dest": "_render"
		},
		{
			"src": "^/404$",
			"dest": "_render"
		},
		{
			"src": "^/about$",
			"dest": "_render"
		},
		{
			"src": "^/ai-tutor$",
			"dest": "_render"
		},
		{
			"src": "^/best-practices/api-security$",
			"dest": "_render"
		},
		{
			"src": "^/best-practices/aws$",
			"dest": "_render"
		},
		{
			"src": "^/best-practices/backend-performance$",
			"dest": "_render"
		},
		{
			"src": "^/best-practices/code-review$",
			"dest": "_render"
		},
		{
			"src": "^/best-practices/frontend-performance$",
			"dest": "_render"
		},
		{
			"src": "^/best-practices$",
			"dest": "_render"
		},
		{
			"src": "^/changelog$",
			"dest": "_render"
		},
		{
			"src": "^/devops/devops-engineer$",
			"dest": "_render"
		},
		{
			"src": "^/get-started$",
			"dest": "_render"
		},
		{
			"src": "^/og/best-practice/([^/]+?)$",
			"dest": "_render"
		},
		{
			"src": "^/og/guide/([^/]+?)$",
			"dest": "_render"
		},
		{
			"src": "^/og/roadmap/([^/]+?)$",
			"dest": "_render"
		},
		{
			"src": "^/og/user/([^/]+?)$",
			"dest": "_render"
		},
		{
			"src": "^/pages\\.json/?$",
			"dest": "_render"
		},
		{
			"src": "^/r/embed$",
			"dest": "_render"
		},
		{
			"src": "^/r/([^/]+?)$",
			"dest": "_render"
		},
		{
			"src": "^/r$",
			"dest": "_render"
		},
		{
			"src": "^/roadmaps$",
			"dest": "_render"
		},
		{
			"src": "^/u/([^/]+?)$",
			"dest": "_render"
		},
		{
			"src": "^/v1-health$",
			"dest": "_render"
		},
		{
			"src": "^/videos$",
			"dest": "_render"
		},
		{
			"src": "^/([^/]+?)\\.json$",
			"dest": "_render"
		},
		{
			"src": "^/([^/]+?)/courses$",
			"dest": "_render"
		},
		{
			"src": "^/([^/]+?)/projects$",
			"dest": "_render"
		},
		{
			"src": "^/([^/]+?)/svg$",
			"dest": "_render"
		},
		{
			"src": "^/([^/]+?)$",
			"dest": "_render"
		},
		{
			"src": "^/([^/]+?)(?:/(.*?))?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}