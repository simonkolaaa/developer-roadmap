---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SavedRoadmapViewer } from '../components/SavedRoadmapViewer';

export const prerender = false;
---

<BaseLayout
  title='La Mia Roadmap — Simonkola Roadmaps'
  description={'Visualizza la tua roadmap salvata localmente.'}
  permalink={'/my-roadmap'}
>
  <div class='min-h-screen bg-slate-950 text-slate-100'>
    <div class='sticky top-[60px] z-10 border-b border-slate-800 bg-slate-900'>
      <div class='container mx-auto flex items-center gap-3 px-4 py-3 text-sm'>
        <a href='/' class='text-slate-400 transition-colors hover:text-blue-400'>
          Home
        </a>
        <span class='text-slate-600'>›</span>
        <span class='font-medium text-slate-300'>Le tue Roadmaps</span>
      </div>
    </div>
    
    <SavedRoadmapViewer client:only="react" />
  </div>
</BaseLayout>
