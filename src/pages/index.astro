---
import { DateTime } from 'luxon';
import ChangelogBanner from '../components/ChangelogBanner.astro';
import { FeaturedGuideList } from '../components/FeaturedGuides/FeaturedGuideList';
import FeaturedItems from '../components/FeaturedItems/FeaturedItems.astro';
import { FeaturedVideoList } from '../components/FeaturedVideos/FeaturedVideoList';
import { HeroSection } from '../components/HeroSection/HeroSection';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllVideos } from '../lib/video';
import { listOfficialGuides } from '../queries/official-guide';
import {
  isNewRoadmap,
  listOfficialRoadmaps,
} from '../queries/official-roadmap';
import { LOCAL_ROADMAPS } from '../data/local-roadmaps';
import { MyRoadmapsList } from '../components/MyRoadmapsList';

const roadmaps = await listOfficialRoadmaps();
const roleRoadmaps = roadmaps.filter((roadmap) => roadmap.type === 'role');
const skillRoadmaps = roadmaps.filter((roadmap) => roadmap.type === 'skill');
const bestPractices = roadmaps.filter(
  (roadmap) => roadmap.type === 'best-practice',
);

export const projectGroups = [
  {
    title: 'Frontend',
    id: 'frontend',
  },
  {
    title: 'Backend',
    id: 'backend',
  },
  {
    title: 'DevOps',
    id: 'devops',
  },
];

const allGuides = await listOfficialGuides();
const questionGuides = allGuides.filter(
  (guide) => guide.roadmapId === 'questions',
);
const guides = allGuides.filter((guide) => guide.roadmapId !== 'questions');

const videos = await getAllVideos();
---

<BaseLayout
  title='Developer Roadmaps - roadmap.sh'
  description={'Community driven roadmaps, articles and guides for developers to grow in their career.'}
  permalink={'/'}
>
  <div slot='ad-slot-script'></div>
  <div slot='ad-slot'></div>

  <div class='bg-slate-950'>
    <HeroSection client:load />

    <!-- ══ PERCORSI PERSONALI (Local Roadmaps) ══════════════════════════════ -->
    <div
      class='relative border-b border-b-white/10 bg-slate-950 py-20 overflow-visible z-30'
    >
      <div class='container relative'>
        <div class="mb-12 flex items-baseline justify-between border-b border-white/10 pb-4">
          <span class="text-xs font-semibold tracking-[0.2em] text-yellow-400 font-orbitron uppercase">// 01 . PERCORSI PERSONALI</span>
          <span class="text-[10px] font-mono text-slate-500 uppercase tracking-widest hidden sm:block">LOCAL JOURNEYS</span>
        </div>
        
        <ul class='flex flex-col w-full relative z-10 border-t border-white/5'>
          {
            LOCAL_ROADMAPS.sort((a, b) => a.order - b.order).map((roadmap, i) => (
              <li 
                class="awwwards-item opacity-0 translate-y-5 transition-all duration-700 ease-out w-full border-b border-white/5"
                style={`transition-delay: ${i * 40}ms`}
              >
                <a
                  href={`/${roadmap.slug}`}
                  class='awwwards-list-item group relative flex w-full items-center justify-between py-6 transition-all duration-300 hover:bg-white/[0.01] px-2 sm:px-4'
                  data-title={roadmap.title.card}
                  data-desc={roadmap.description}
                  data-type={roadmap.type}
                  data-topics={roadmap.topics ? `${roadmap.topics.length} TOPICS` : "0 TOPICS"}
                >
                  <div class="relative z-10 flex items-center gap-4 sm:gap-8">
                    <span class='text-xs font-mono text-yellow-500/40 tracking-wider w-8 shrink-0'>
                      // {(i + 1).toString().padStart(2, '0')}
                    </span>
                    
                    <!-- Kinetic Text Roll Effect (Symmetric) -->
                    <div class="h-[1.3em] overflow-hidden relative flex items-center pr-2">
                      <span class="block text-xl font-bold tracking-tight text-slate-300 transition-transform duration-500 ease-[0.16,1,0.3,1] group-hover:-translate-y-full sm:text-3xl uppercase font-orbitron">{roadmap.title.card}</span>
                      <span class="absolute top-full left-0 block text-xl font-bold tracking-tight text-yellow-400 transition-transform duration-500 ease-[0.16,1,0.3,1] group-hover:-translate-y-full sm:text-3xl uppercase font-orbitron">{roadmap.title.card}</span>
                    </div>
                  </div>
                  
                  <div class="relative z-20 flex items-center gap-6">
                    <div class="hidden sm:flex items-center gap-4">
                      <span class="text-[9px] font-mono border border-slate-800 rounded px-2 py-0.5 text-slate-500 group-hover:border-yellow-500/30 group-hover:text-yellow-400 transition-colors duration-300">
                        {roadmap.type === 'role' ? 'RUOLO' : 'COMPETENZA'}
                      </span>
                      <span class="text-[10px] font-mono text-slate-500 group-hover:text-slate-300 transition-colors duration-300">
                        {roadmap.topics ? `${roadmap.topics.length} ARGOMENTI` : '0 ARGOMENTI'}
                      </span>
                    </div>

                    <div class="flex h-8 w-8 items-center justify-center rounded-full border border-white/10 bg-slate-900/40 text-slate-400 transition-all duration-300 group-hover:border-yellow-400/40 group-hover:bg-yellow-500/10 group-hover:text-yellow-400 group-hover:rotate-45">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </div>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>

        <!-- Shared Floating Preview Card (Clean, Sharp Dark theme from mohamedshehata.net) -->
        <div
          id="floating-preview"
          class="pointer-events-none fixed top-0 left-0 z-50 h-[170px] w-[270px] opacity-0 scale-95 rounded-xl border border-white/10 bg-slate-950/95 p-5 shadow-[0_30px_60px_rgba(0,0,0,0.8)] backdrop-blur-md transition-all duration-300 ease-out flex flex-col justify-between overflow-hidden"
          style="transform: translate3d(-100%, -100%, 0) rotate(0deg); transform-origin: center center;"
        >
          {/* Subtle line background decoration */}
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-yellow-500/20 to-transparent"></div>
          
          <div class="relative z-10 flex flex-col h-full justify-between">
            <div>
              <span id="preview-type" class="text-[8px] font-bold uppercase tracking-[0.2em] text-yellow-500/70 font-mono">// RUOLO</span>
              <h4 id="preview-title" class="mt-1 text-md font-bold tracking-tight text-slate-200 uppercase font-orbitron line-clamp-1">FONDAMENTI</h4>
              <p id="preview-desc" class="mt-1.5 text-xs text-slate-400 leading-relaxed line-clamp-2">Basi della programmazione, algoritmi e strutture dati.</p>
            </div>
            
            <div class="flex items-center justify-between border-t border-white/5 pt-3">
              <span class="text-[9px] text-slate-500 font-mono tracking-wider" id="preview-count">8 TOPICS</span>
              <span class="text-[9px] text-yellow-400 font-mono tracking-widest flex items-center gap-1">
                STUDIA ORA
                <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </div>
          </div>
        </div>

      </div>
    </div>
    <div class='container'>
      <MyRoadmapsList client:only='react' />
    </div>

    <FeaturedItems
      heading='Role-based Roadmaps'
      featuredItems={roleRoadmaps.map((roadmapItem) => {
        const isNew = isNewRoadmap(roadmapItem.createdAt);

        return {
          text: roadmapItem.title.card,
          url: `/${roadmapItem.slug}`,
          isNew,
        };
      })}
      showCreateRoadmap={true}
    />

    <FeaturedItems
      heading='Skill-based Roadmaps'
      featuredItems={skillRoadmaps.map((roadmapItem) => {
        const isNew = isNewRoadmap(roadmapItem.createdAt);

        return {
          text:
            roadmapItem.title.card === 'Go'
              ? 'Go Roadmap'
              : roadmapItem.title.card.replace('Software Design', 'Design'),
          url: `/${roadmapItem.slug}`,
          isNew,
        };
      })}
      showCreateRoadmap={true}
    />

    <div class='grid grid-cols-1 gap-7 bg-gray-50 py-7 sm:gap-16 sm:py-16'>
      <FeaturedVideoList heading='Videos' videos={videos.slice(0, 7)} />
    </div>
  </div>
  <ChangelogBanner slot='changelog-banner' />
</BaseLayout>

<script>
  function setupAwwwardsPreviews() {
    let targetX = 0;
    let targetY = 0;
    let currentX = 0;
    let currentY = 0;
    let velocityX = 0;
    let lastX = 0;
    let lastTime = Date.now();
    let rotate = 0;
    let isHovered = false;

    const preview = document.getElementById('floating-preview');
    const items = document.querySelectorAll('.awwwards-list-item');

    if (!preview) return;

    const handleMouseMove = (e: MouseEvent) => {
      // Offset preview slightly so it sits next to the cursor elegantly
      targetX = e.clientX + 30;
      targetY = e.clientY - 90;
    };

    window.addEventListener('mousemove', handleMouseMove);

    items.forEach((item) => {
      const handleMouseEnter = () => {
        isHovered = true;
        
        const title = item.getAttribute('data-title') || '';
        const desc = item.getAttribute('data-desc') || '';
        const type = item.getAttribute('data-type') || '';
        const topics = item.getAttribute('data-topics') || '';

        const titleEl = document.getElementById('preview-title');
        const descEl = document.getElementById('preview-desc');
        const typeEl = document.getElementById('preview-type');
        const countEl = document.getElementById('preview-count');

        if (titleEl) titleEl.textContent = title;
        if (descEl) descEl.textContent = desc;
        
        let displayType = 'COMPETENZA';
        if (type === 'role') displayType = 'RUOLO / PROFESSIONE';
        if (type === 'best-practice') displayType = 'BEST PRACTICE';
        if (typeEl) typeEl.textContent = displayType;
        
        if (countEl) countEl.textContent = topics;

        preview.classList.remove('opacity-0', 'scale-90');
        preview.classList.add('opacity-100', 'scale-100');
      };

      const handleMouseLeave = () => {
        isHovered = false;
        preview.classList.remove('opacity-100', 'scale-100');
        preview.classList.add('opacity-0', 'scale-90');
      };

      item.addEventListener('mouseenter', handleMouseEnter);
      item.addEventListener('mouseleave', handleMouseLeave);
    });

    let frameId: number;
    const tick = () => {
      const currentTime = Date.now();
      const dt = Math.max(currentTime - lastTime, 1);
      lastTime = currentTime;

      // Elastic Spring Interpolation (Inertia Lag)
      const lerpFactor = 0.08;
      currentX += (targetX - currentX) * lerpFactor;
      currentY += (targetY - currentY) * lerpFactor;

      velocityX = (currentX - lastX) / dt;
      lastX = currentX;

      // 3D perspective velocity tilt (rotazione proporzionale alla velocità del mouse)
      const targetRotate = Math.min(Math.max(velocityX * 10, -12), 12);
      rotate += (targetRotate - rotate) * 0.15;

      preview.style.transform = `translate3d(${currentX}px, ${currentY}px, 0) rotate(${rotate}deg)`;

      frameId = requestAnimationFrame(tick);
    };

    frameId = requestAnimationFrame(tick);

    // Evita duplicazione di listener ed animazioni durante la navigazione Astro View Transitions
    document.addEventListener('astro:before-preparation', () => {
      window.removeEventListener('mousemove', handleMouseMove);
      cancelAnimationFrame(frameId);
    }, { once: true });
  }

  document.addEventListener('astro:page-load', setupAwwwardsPreviews);
</script>
