---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { VisualRoadmapRenderer } from '../../components/VisualRoadmapRenderer';
import { LOCAL_ROADMAPS } from '../../data/local-roadmaps';

export const prerender = false;

const { slug } = Astro.params;
const roadmap = LOCAL_ROADMAPS.find(r => r.slug === slug);
const isFullScreen = slug === 'maturita';

if (!roadmap) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not found';
  return Astro.rewrite('/404');
}
---

<BaseLayout
  title={`${roadmap.title.page} — SimonKola Roadmaps`}
  description={roadmap.description}
>
  <div class="min-h-screen bg-slate-950 text-slate-100">

    <div class="border-b border-slate-800 bg-slate-900 sticky top-[60px] z-10">
      <div class="container mx-auto px-4 py-3 flex items-center gap-3 text-sm">
        <a href="/" class="text-slate-400 hover:text-blue-400 transition-colors">Home</a>
        <span class="text-slate-600">›</span>
        <span class="text-slate-300 font-medium">{roadmap.title.card}</span>
      </div>
    </div>

    <div class="bg-gradient-to-b from-slate-900 to-slate-950 border-b border-slate-800 py-12">
      <div class={isFullScreen ? "w-full px-4 md:px-12" : "container mx-auto px-4 max-w-4xl"}>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-xs font-medium mb-5 uppercase tracking-widest">
          {roadmap.type === 'role' ? '🎓 Percorso di Studio' : '⚡ Skill Track'}
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">
          {roadmap.title.page}
        </h1>
        <p class="text-slate-400 text-base max-w-2xl leading-relaxed">
          {roadmap.description}
        </p>
      </div>
    </div>

    <div class={isFullScreen ? "w-full px-4 md:px-12 py-10" : "container mx-auto px-4 py-10 max-w-4xl"}>
      <VisualRoadmapRenderer
        roadmapId={slug}
        client:only="react"
      />
    </div>

  </div>
</BaseLayout>
