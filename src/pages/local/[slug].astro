---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { VisualRoadmapRenderer } from '../../components/VisualRoadmapRenderer';
import { LOCAL_ROADMAPS } from '../../data/local-roadmaps';

export const prerender = false;

const { slug } = Astro.params;
const roadmap = LOCAL_ROADMAPS.find((r) => r.slug === slug);
const isFullScreen = slug === 'maturita';

if (!roadmap) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not found';
  return Astro.rewrite('/404');
}
---

<BaseLayout
  title={`${roadmap.title.page} — SimonKola Roadmaps`}
  description={roadmap.description}
>
  <div class='min-h-screen bg-slate-950 text-slate-100'>
    <div class='sticky top-[60px] z-10 border-b border-slate-800 bg-slate-900'>
      <div class='container mx-auto flex items-center gap-3 px-4 py-3 text-sm'>
        <a href='/' class='text-slate-400 transition-colors hover:text-blue-400'
          >Home</a
        >
        <span class='text-slate-600'>›</span>
        <span class='font-medium text-slate-300'>{roadmap.title.card}</span>
      </div>
    </div>

    <div
      class='border-b border-slate-800 bg-gradient-to-b from-slate-900 to-slate-950 py-12'
    >
      <div
        class={isFullScreen
          ? 'w-full px-4 md:px-12'
          : 'container mx-auto px-4 max-w-4xl'}
      >
        <div
          class='mb-5 inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-3 py-1 text-xs font-medium tracking-widest text-blue-400 uppercase'
        >
          {roadmap.type === 'role' ? '🎓 Percorso di Studio' : '⚡ Skill Track'}
        </div>
        <h1
          class='mb-3 text-3xl font-bold tracking-tight text-white md:text-4xl'
        >
          {roadmap.title.page}
        </h1>
        <p class='max-w-2xl text-base leading-relaxed text-slate-400'>
          {roadmap.description}
        </p>
      </div>
    </div>

    <div
      class={isFullScreen
        ? 'w-full px-4 md:px-12 py-10'
        : 'container mx-auto px-4 py-10 max-w-4xl'}
    >
      <VisualRoadmapRenderer roadmapId={slug} client:only='react' />
    </div>
  </div>
</BaseLayout>
