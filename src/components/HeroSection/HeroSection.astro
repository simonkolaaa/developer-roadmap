---
import { FeatureAnnouncement } from '../FeatureAnnouncement';
---

<div
  class='relative min-h-[192px] min-h-auto border-b border-b-[#1e293c] transition-all sm:min-h-[281px]'
>
  <div
    class='container px-5 py-6 pb-14 text-left transition-opacity duration-300 sm:px-0 sm:py-20 sm:text-center'
    id='hero-text'
  >
    <p class='-mt-4 mb-7 sm:-mt-10 sm:mb-4'>
      <FeatureAnnouncement client:load />
    </p>

    <h1
      class='mb-2 bg-linear-to-r from-blue-400 via-indigo-400 to-purple-500 bg-clip-text text-3xl font-extrabold text-transparent sm:mb-4 sm:text-6xl sm:leading-tight'
    >
      Simon Kola Roadmaps
    </h1>

    <p class='mx-auto hidden max-w-2xl px-4 text-xl text-slate-400 sm:block'>
      <span class='font-bold text-blue-400'>My Personal Journey</span>. A
      curated collection of computer science roadmaps, university notes and
      essential resources for modern development.
    </p>

    <p class='text-md block px-0 text-slate-400 sm:hidden'>
      Personal roadmaps, university notes and articles to master software
      engineering.
    </p>

    <div
      class='mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row'
    >
      <a
        href='/ai'
        class='inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-blue-600 to-purple-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-500/20 transition-all hover:scale-105 hover:from-blue-500 hover:to-purple-500'
      >
        <span>✨ Generate Roadmaps with Gemma AI</span>
      </a>
    </div>
  </div>
</div>
