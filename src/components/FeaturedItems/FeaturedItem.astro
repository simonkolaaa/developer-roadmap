---
import AstroIcon from '../AstroIcon.astro';
import { MarkFavorite } from './MarkFavorite';
export interface FeaturedItemType {
  isUpcoming?: boolean;
  isNew?: boolean;
  url: string;
  text: string;
  allowBookmark?: boolean;
}

export interface Props extends FeaturedItemType {}

const {
  isUpcoming = false,
  isNew = false,
  text,
  url,
  allowBookmark = true,
} = Astro.props;
---

<a
  class:list={[
    'awwwards-list-item group relative flex w-full items-center justify-between border-b border-slate-800/50 py-6 transition-all duration-500 hover:border-purple-500/30 hover:bg-slate-900/40 hover:px-6 hover:shadow-[0_0_30px_rgba(168,85,247,0.15)] sm:py-8',
    {
      'opacity-50': isUpcoming,
    },
  ]}
  href={url}
>
  <div class="flex items-center gap-6 z-20">
    <span class="text-3xl font-extrabold tracking-tighter text-slate-300 transition-all duration-500 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-blue-400 group-hover:to-purple-500 sm:text-5xl">
      {text}
    </span>

    {
      isNew && (
        <span class='flex items-center rounded-full bg-purple-900/30 px-3 py-1 text-xs font-medium text-purple-300 border border-purple-500/20'>
          <span class='mr-2 relative flex h-2 w-2'>
            <span class='absolute inline-flex h-2 w-2 animate-ping rounded-full bg-purple-400 opacity-75' />
            <span class='relative inline-flex h-2 w-2 rounded-full bg-purple-500' />
          </span>
          New
        </span>
      )
    }

    {
      isUpcoming && (
        <span class='flex items-center rounded-full bg-slate-800 px-3 py-1 text-xs font-medium text-slate-400 border border-slate-700'>
          Upcoming
        </span>
      )
    }
  </div>

  <div class="relative z-20 flex items-center opacity-0 transition-opacity duration-300 group-hover:opacity-100">
    <div class="flex h-12 w-12 items-center justify-center rounded-full border border-purple-500/30 bg-purple-500/10 text-purple-400 backdrop-blur-sm transition-transform duration-500 group-hover:rotate-45">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </div>
  </div>

  {
    allowBookmark && (
      <div class="absolute right-0 top-0 z-30 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
        <MarkFavorite
          resourceId={url.split('/').pop()!}
          resourceType={
            url.includes('best-practices') ? 'best-practice' : 'roadmap'
          }
          client:only='react'
        />
      </div>
    )
  }
  
  <span
    data-progress
    class='absolute top-0 bottom-0 left-0 z-10 w-0 bg-purple-900/10 transition-[width] duration-300'
  ></span>
</a>

<script>
  // Simple listener for page loads
  document.addEventListener("astro:page-load", () => {
    // any initialization if needed
  });
</script>
