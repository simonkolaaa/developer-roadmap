---
---

<header
  id="floating-nav"
  class="fixed top-4 left-1/2 -translate-x-1/2 z-[9999] flex items-center gap-3 py-2 pl-4 pr-2 border rounded-full shadow-[0_20px_60px_rgba(0,0,0,0.5)] backdrop-blur-xl transition-all duration-500 max-w-[95vw] md:max-w-none w-max nav-hidden"
  style="background: rgba(13,13,31,0.75); border-color: rgba(139,92,246,0.18);"
>
  <!-- Logo -->
  <a
    class='flex items-center gap-1.5 text-sm font-bold tracking-tight text-white transition-all group'
    href='/'
    aria-label='Home — Dev.Roadmaps'
  >
    <!-- Logo icon -->
    <div class="flex h-6 w-6 items-center justify-center rounded-md transition-all duration-300 group-hover:scale-110" style="background: linear-gradient(135deg, #8B5CF6, #22D3EE);">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M2 2h3v3H2zM7 2h3v3H7zM2 7h3v3H2zM7 9.5L10 7" stroke="white" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <span class='font-space-grotesk font-semibold'>
      <span class='text-violet-300 group-hover:text-violet-200 transition-colors duration-300'>Dev</span><span class='text-slate-300 group-hover:text-white transition-colors duration-300 font-light'>.Roadmaps</span>
    </span>
  </a>

  <!-- Vertical separator -->
  <div class="h-4 w-px" style="background: rgba(139,92,246,0.2);"></div>

  <!-- Nav links -->
  <div class="relative flex items-center z-10">
    <!-- Sliding indicator -->
    <div
      id="nav-indicator"
      class="absolute top-0 left-0 h-full rounded-full -z-10 transition-all duration-300 opacity-0"
      style="width: 0px; transform: translate3d(0, 0, 0); ease: cubic-bezier(0.16,1,0.3,1);"
    ></div>

    <a
      href='/'
      class='nav-link text-xs font-semibold px-3 py-1.5 text-slate-400 hover:text-white transition-colors duration-200 rounded-full'
      data-path="/"
    >
      Home
    </a>
    <a
      href='/roadmaps'
      class='nav-link text-xs font-semibold px-3 py-1.5 text-slate-400 hover:text-white transition-colors duration-200 rounded-full'
      data-path="/roadmaps"
    >
      Roadmaps
    </a>
    <a
      href='/about'
      class='nav-link text-xs font-semibold px-3 py-1.5 text-slate-400 hover:text-white transition-colors duration-200 rounded-full'
      data-path="/about"
    >
      About
    </a>
  </div>

  <!-- AI CTA button -->
  <a
    href='/ai'
    id="nav-ai-btn"
    class="relative flex items-center gap-1.5 rounded-full px-3.5 py-1.5 text-[10px] font-semibold tracking-wider text-white uppercase overflow-hidden transition-all duration-300 hover:scale-105 cursor-pointer"
    style="background: linear-gradient(135deg, #7C3AED, #0891B2);"
    aria-label="Generate with AI"
  >
    <!-- Shimmer -->
    <span class="nav-ai-shimmer absolute inset-0 rounded-full opacity-0"></span>
    <!-- Icon -->
    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="relative z-10">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
    <span class="relative z-10">AI</span>
    <!-- Pulse ring -->
    <span class="nav-ai-pulse absolute -inset-0.5 rounded-full opacity-0"></span>
  </a>
</header>

<style>
  /* Entrance animation */
  .nav-hidden {
    opacity: 0;
    transform: translateX(-50%) translateY(-24px);
  }
  .nav-visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* Scroll-aware */
  .nav-scrolled {
    background: rgba(8, 8, 20, 0.90) !important;
    border-color: rgba(139, 92, 246, 0.08) !important;
    box-shadow: 0 12px 50px rgba(0, 0, 0, 0.7), 0 0 0 1px rgba(139,92,246,0.1) !important;
  }

  /* AI button pulse */
  @keyframes ai-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(124, 58, 237, 0.6); opacity: 1; }
    50%       { box-shadow: 0 0 0 6px rgba(124, 58, 237, 0);  opacity: 0; }
  }
  .nav-ai-pulse {
    animation: ai-pulse 2.5s ease-in-out infinite;
    border: 1px solid rgba(124, 58, 237, 0.4);
  }

  /* AI button shimmer on hover */
  @keyframes shimmer-slide {
    0%   { transform: skewX(-15deg) translateX(-200%); opacity: 0.4; }
    100% { transform: skewX(-15deg) translateX(200%);  opacity: 0; }
  }
  #nav-ai-btn:hover .nav-ai-shimmer {
    animation: shimmer-slide 0.7s ease forwards;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
  }
</style>

<script>
  function setupNavigation() {
    const nav = document.getElementById('floating-nav');
    const indicator = document.getElementById('nav-indicator');
    const links = document.querySelectorAll('.nav-link');
    const currentPath = window.location.pathname;

    if (!nav || !indicator) return;

    // Entrance animation
    const introPlayed = sessionStorage.getItem('intro_played');
    const entranceDelay = introPlayed ? 300 : 3400;

    setTimeout(() => {
      nav.classList.remove('nav-hidden');
      nav.classList.add('nav-visible');
    }, entranceDelay);

    // Scroll behavior
    let lastScrollY = 0;
    const handleScroll = () => {
      const scrollY = window.scrollY;
      if (scrollY > 60) nav.classList.add('nav-scrolled');
      else nav.classList.remove('nav-scrolled');

      if (scrollY > lastScrollY && scrollY > 200) {
        nav.style.transform = 'translateX(-50%) translateY(-80px)';
      } else {
        nav.style.transform = 'translateX(-50%) translateY(0)';
      }
      lastScrollY = scrollY;
    };
    window.addEventListener('scroll', handleScroll, { passive: true });

    // Sliding indicator
    let activeLink: HTMLElement | null = null;

    links.forEach((link) => {
      const path = link.getAttribute('data-path');
      if (path === '/' && currentPath === '/') {
        activeLink = link as HTMLElement;
      } else if (path !== '/' && currentPath.startsWith(path || '')) {
        activeLink = link as HTMLElement;
      }

      link.addEventListener('mouseenter', () => {
        const rect = (link as HTMLElement).getBoundingClientRect();
        const parentRect = link.parentElement!.getBoundingClientRect();
        indicator.style.width  = `${rect.width}px`;
        indicator.style.left   = `${rect.left - parentRect.left}px`;
        indicator.style.opacity = '1';
        indicator.style.background = 'rgba(139, 92, 246, 0.12)';
      });
    });

    const linksContainer = indicator.parentElement;
    if (linksContainer) {
      linksContainer.addEventListener('mouseleave', resetToActive);
    }

    function resetToActive() {
      if (activeLink && indicator) {
        const rect = activeLink.getBoundingClientRect();
        const parentRect = activeLink.parentElement!.getBoundingClientRect();
        indicator.style.width  = `${rect.width}px`;
        indicator.style.left   = `${rect.left - parentRect.left}px`;
        indicator.style.opacity = '1';
        indicator.style.background = 'linear-gradient(135deg, rgba(139,92,246,0.25), rgba(34,211,238,0.15))';
      } else if (indicator) {
        indicator.style.opacity = '0';
        indicator.style.width   = '0px';
      }
    }

    setTimeout(resetToActive, entranceDelay + 200);
  }

  document.addEventListener('astro:page-load', setupNavigation);
</script>
