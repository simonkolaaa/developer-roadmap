---
---

<header
  id="floating-nav"
  class="fixed top-5 left-1/2 -translate-x-1/2 z-[9999] flex items-center gap-4 py-1.5 pl-5 pr-1.5 bg-slate-950/60 border border-white/10 rounded-full shadow-[0_20px_50px_rgba(0,0,0,0.4)] backdrop-blur-xl transition-all duration-300 max-w-[95vw] md:max-w-md w-max"
>
  <a
    class='flex items-center text-sm font-black tracking-tight text-white transition-colors font-orbitron'
    href='/'
    aria-label='Home'
  >
    <span class='text-yellow-400'>Dev</span>
    <span class='text-slate-300 font-light ml-0.5'>.Roadmaps</span>
  </a>

  <!-- Separatore verticale -->
  <div class="h-4 w-px bg-white/15"></div>

  <!-- Link di Navigazione -->
  <div class="relative flex items-center z-10">
    <!-- Indicatore Scivolante Attivo/Hover -->
    <div
      id="nav-indicator"
      class="absolute top-0 left-0 h-full bg-yellow-500/90 rounded-full -z-10 transition-all duration-300 ease-[0.16,1,0.3,1] opacity-0"
      style="width: 0px; transform: translate3d(0, 0, 0);"
    ></div>

    <a
      href='/'
      class='nav-link text-xs font-semibold px-3.5 py-1.5 text-slate-400 hover:text-white transition-colors duration-200 rounded-full'
      data-path="/"
    >
      Home
    </a>
    <a
      href='/roadmaps'
      class='nav-link text-xs font-semibold px-3.5 py-1.5 text-slate-400 hover:text-white transition-colors duration-200 rounded-full'
      data-path="/roadmaps"
    >
      Roadmaps
    </a>
    <a
      href='/about'
      class='nav-link text-xs font-semibold px-3.5 py-1.5 text-slate-400 hover:text-white transition-colors duration-200 rounded-full'
      data-path="/about"
    >
      About
    </a>
  </div>
</header>

<script>
  function setupNavIndicator() {
    const indicator = document.getElementById('nav-indicator');
    const links = document.querySelectorAll('.nav-link');
    const currentPath = window.location.pathname;

    if (!indicator) return;

    let activeLink: HTMLElement | null = null;

    links.forEach((link) => {
      const path = link.getAttribute('data-path');
      
      // Match percorsi esatti o sottopagine
      if (path === '/' && currentPath === '/') {
        activeLink = link as HTMLElement;
      } else if (path !== '/' && currentPath.startsWith(path || '')) {
        activeLink = link as HTMLElement;
      }

      // Hover: l'indicatore si sposta sul link corrente con stile "soffuso"
      link.addEventListener('mouseenter', () => {
        const rect = (link as HTMLElement).getBoundingClientRect();
        const parentRect = link.parentElement!.getBoundingClientRect();
        
        indicator.style.width = `${rect.width}px`;
        indicator.style.left = `${rect.left - parentRect.left}px`;
        indicator.style.opacity = '1';
        indicator.classList.remove('bg-yellow-500/90');
        indicator.classList.add('bg-white/10');
      });
    });

    // Quando esce dall'area nav, l'indicatore ritorna sul link attivo
    const linksContainer = indicator.parentElement;
    if (linksContainer) {
      linksContainer.addEventListener('mouseleave', () => {
        resetToActive();
      });
    }

    function resetToActive() {
      if (activeLink && indicator) {
        const rect = activeLink.getBoundingClientRect();
        const parentRect = activeLink.parentElement!.getBoundingClientRect();
        
        indicator.style.width = `${rect.width}px`;
        indicator.style.left = `${rect.left - parentRect.left}px`;
        indicator.style.opacity = '1';
        indicator.classList.add('bg-yellow-500/90');
        indicator.classList.remove('bg-white/10');
      } else if (indicator) {
        indicator.style.opacity = '0';
        indicator.style.width = '0px';
      }
    }

    // Inizializza la posizione
    setTimeout(resetToActive, 100);
  }

  document.addEventListener('astro:page-load', setupNavIndicator);
</script>
