---
import Icon from '../AstroIcon.astro';
---

<div class='bg-slate-900 py-4 text-white shadow-md sm:py-6'>
  <nav class='container flex items-center justify-between'>
    <div class='flex items-center gap-5'>
      <a
        class='flex items-center text-xl font-bold tracking-tight text-white transition-colors hover:text-blue-400'
        href='/'
        aria-label='Home'
      >
        <span
          class='bg-gradient-to-r from-blue-400 to-indigo-500 bg-clip-text text-transparent'
          >Dev</span
        >
        <span class='ml-1'>Roadmaps</span>
      </a>

      <!-- Desktop navigation items -->
      <div class='ml-4 hidden gap-6 sm:flex sm:items-center'>
        <a
          href='/roadmaps'
          class='text-sm font-medium text-gray-300 transition-colors hover:text-white'
          >Roadmaps</a
        >
        <a
          href='/about'
          class='text-sm font-medium text-gray-300 transition-colors hover:text-white'
          >About</a
        >
      </div>
    </div>

    <!-- Mobile Navigation Button -->
    <button
      class='block cursor-pointer text-gray-400 hover:text-gray-50 sm:hidden'
      aria-label='Menu'
      data-show-mobile-nav
    >
      <Icon icon='hamburger' />
    </button>

    <!-- Mobile Navigation Items -->
    <div
      class='bg-opacity-95 fixed top-0 right-0 bottom-0 left-0 z-40 flex hidden items-center justify-center bg-slate-900 backdrop-blur-sm'
      data-mobile-nav
    >
      <button
        data-close-mobile-nav
        class='absolute top-6 right-6 block cursor-pointer text-gray-400 hover:text-gray-50'
        aria-label='Close Menu'
      >
        <Icon icon='close' />
      </button>
      <ul class='flex w-full flex-col items-center gap-6'>
        <li>
          <a
            href='/'
            class='text-2xl font-semibold text-white hover:text-blue-400'
          >
            Home
          </a>
        </li>
        <li>
          <a
            href='/roadmaps'
            class='text-2xl font-semibold text-white hover:text-blue-400'
          >
            Roadmaps
          </a>
        </li>
      </ul>
    </div>
  </nav>
</div>

<script>
  // Simple mobile menu toggle
  const mobileNav = document.querySelector('[data-mobile-nav]');
  const showMobileNav = document.querySelector('[data-show-mobile-nav]');
  const closeMobileNav = document.querySelector('[data-close-mobile-nav]');

  if (showMobileNav && mobileNav && closeMobileNav) {
    showMobileNav.addEventListener('click', () => {
      mobileNav.classList.remove('hidden');
    });

    closeMobileNav.addEventListener('click', () => {
      mobileNav.classList.add('hidden');
    });
  }
</script>
