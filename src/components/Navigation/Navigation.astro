---
---

<header
  id="floating-nav"
  class="fixed top-5 left-1/2 -translate-x-1/2 z-[9999] flex items-center gap-4 py-1.5 pl-5 pr-1.5 bg-slate-950/60 border border-white/10 rounded-full shadow-[0_20px_50px_rgba(0,0,0,0.4)] backdrop-blur-xl transition-all duration-500 max-w-[95vw] md:max-w-md w-max nav-hidden"
>
  <a
    class='flex items-center text-sm font-black tracking-tight text-white transition-colors font-orbitron group'
    href='/'
    aria-label='Home'
  >
    <span class='text-yellow-400 group-hover:text-yellow-300 transition-colors duration-300'>Dev</span>
    <span class='text-slate-300 font-light ml-0.5 group-hover:text-white transition-colors duration-300'>.Roadmaps</span>
  </a>

  <!-- Separatore verticale -->
  <div class="h-4 w-px bg-white/15"></div>

  <!-- Link di Navigazione -->
  <div class="relative flex items-center z-10">
    <!-- Indicatore Scivolante Attivo/Hover -->
    <div
      id="nav-indicator"
      class="absolute top-0 left-0 h-full bg-yellow-500/90 rounded-full -z-10 transition-all duration-300 ease-[0.16,1,0.3,1] opacity-0"
      style="width: 0px; transform: translate3d(0, 0, 0);"
    ></div>

    <a
      href='/'
      class='nav-link text-xs font-semibold px-3.5 py-1.5 text-slate-400 hover:text-white transition-colors duration-200 rounded-full'
      data-path="/"
    >
      Home
    </a>
    <a
      href='/roadmaps'
      class='nav-link text-xs font-semibold px-3.5 py-1.5 text-slate-400 hover:text-white transition-colors duration-200 rounded-full'
      data-path="/roadmaps"
    >
      Roadmaps
    </a>
    <a
      href='/about'
      class='nav-link text-xs font-semibold px-3.5 py-1.5 text-slate-400 hover:text-white transition-colors duration-200 rounded-full'
      data-path="/about"
    >
      About
    </a>
  </div>
</header>

<style>
  /* Navbar entrance animation */
  .nav-hidden {
    opacity: 0;
    transform: translateX(-50%) translateY(-20px);
  }
  .nav-visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* Scroll-aware: navbar shrinks and gets more opaque on scroll */
  .nav-scrolled {
    background: rgba(2, 6, 23, 0.85);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
  }
</style>

<script>
  function setupNavigation() {
    const nav = document.getElementById('floating-nav');
    const indicator = document.getElementById('nav-indicator');
    const links = document.querySelectorAll('.nav-link');
    const currentPath = window.location.pathname;

    if (!nav || !indicator) return;

    // Delayed entrance animation (after preloader)
    const introPlayed = sessionStorage.getItem('intro_played');
    const entranceDelay = introPlayed ? 300 : 3400;
    
    setTimeout(() => {
      nav.classList.remove('nav-hidden');
      nav.classList.add('nav-visible');
    }, entranceDelay);

    // Scroll-aware class toggle
    let lastScrollY = 0;
    const handleScroll = () => {
      const scrollY = window.scrollY;
      
      if (scrollY > 60) {
        nav.classList.add('nav-scrolled');
      } else {
        nav.classList.remove('nav-scrolled');
      }

      // Hide navbar on fast scroll down, show on scroll up
      if (scrollY > lastScrollY && scrollY > 200) {
        nav.style.transform = 'translateX(-50%) translateY(-80px)';
      } else {
        nav.style.transform = 'translateX(-50%) translateY(0)';
      }
      lastScrollY = scrollY;
    };

    window.addEventListener('scroll', handleScroll, { passive: true });

    // Nav indicator logic
    let activeLink: HTMLElement | null = null;

    links.forEach((link) => {
      const path = link.getAttribute('data-path');
      
      if (path === '/' && currentPath === '/') {
        activeLink = link as HTMLElement;
      } else if (path !== '/' && currentPath.startsWith(path || '')) {
        activeLink = link as HTMLElement;
      }

      link.addEventListener('mouseenter', () => {
        const rect = (link as HTMLElement).getBoundingClientRect();
        const parentRect = link.parentElement!.getBoundingClientRect();
        
        indicator.style.width = `${rect.width}px`;
        indicator.style.left = `${rect.left - parentRect.left}px`;
        indicator.style.opacity = '1';
        indicator.style.backgroundColor = 'rgba(255, 255, 255, 0.1)';
      });
    });

    const linksContainer = indicator.parentElement;
    if (linksContainer) {
      linksContainer.addEventListener('mouseleave', () => {
        resetToActive();
      });
    }

    function resetToActive() {
      if (activeLink && indicator) {
        const rect = activeLink.getBoundingClientRect();
        const parentRect = activeLink.parentElement!.getBoundingClientRect();
        
        indicator.style.width = `${rect.width}px`;
        indicator.style.left = `${rect.left - parentRect.left}px`;
        indicator.style.opacity = '1';
        indicator.style.backgroundColor = 'rgba(234, 179, 8, 0.9)';
      } else if (indicator) {
        indicator.style.opacity = '0';
        indicator.style.width = '0px';
      }
    }

    setTimeout(resetToActive, entranceDelay + 200);
  }

  document.addEventListener('astro:page-load', setupNavigation);
</script>
